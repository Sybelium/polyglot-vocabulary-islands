  },
  "lyrics": {
    "sections": [
      {
        "name": "Opening",
        "start": 0.0,
        "end": 30.0,
        "lines": [
          {
            "quenya": "Mi lómë cemessë,",
            "english": "In the silence of the earth,"
          },
          {
            "quenya": "yassë súrë yesta,",
            "english": "where the wind begins to call,"
          },
          {
            "quenya": "síressë, ëarissë,",
            "english": "by the river, by the sea,"
          },
          {
            "quenya": "nórë nu lómë esta",
            "english": "there’s a hidden world for all"
          }
        ]
      },
      {
        "name": "Journey",
        "start": 30.0,
        "end": 50.0,
        "lines": [
          {
            "quenya": "Mi taurë lómëa nu,",
            "english": "Through the forest, dark and deep,"
          },
          {
            "quenya": "oronti or i alta,",
            "english": "past the mountains standing high,"
          },
          {
            "quenya": "síressë yassë lumbor caita,",
            "english": "by the lake where shadows sleep,"
          },
          {
            "quenya": "menel nu pella",
            "english": "underneath the open sky"
          }
        ]
      },
      {
        "name": "Whispers",
        "start": 50.0,
        "end": 70.0,
        "lines": [
          {
            "quenya": "Aiwi lírir mi súrë,",
            "english": "Trees are whispering in the air,"
          },
          {
            "quenya": "lótë liltë calaressë,",
            "english": "Flowers dancing in the light,"
          },
          {
            "quenya": "sarnë caita nárë,",
            "english": "Rocks are resting everywhere,"
          },
          {
            "quenya": "tulir lindalë lómessë",
            "english": "Guiding travelers through the night"
          }
        ]
      },
      {
        "name": "Elements",
        "start": 70.0,
        "end": 90.0,
        "lines": [
          {
            "quenya": "Nén sirya ar uru calë,",
            "english": "Water flows and fire burns,"
          },
          {
            "quenya": "cemë tulca nu talma,",
            "english": "Earth is strong beneath our feet,"
          },
          {
            "quenya": "súrë orta ar váta,",
            "english": "Wind will rise and slowly turn,"
          },
          {
            "quenya": "vilya ar menel ar ilya",
            "english": "Air and sky and all we meet"
          }
        ]
      },
      {
        "name": "Life",
        "start": 90.0,
        "end": 110.0,
        "lines": [
          {
            "quenya": "Olvar orta ar rávar norta,",
            "english": "Plants will grow and animals run,"
          },
          {
            "quenya": "fanyar hosta mi luinë,",
            "english": "Clouds will gather in the blue,"
          },
          {
            "quenya": "lossë lanta ar anar túra,",
            "english": "Rain will fall, then comes the sun,"
          },
          {
            "quenya": "caitalë ilyë lírë",
            "english": "Painting life in every hue"
          }
        ]
      },
      {
        "name": "Climax",
        "start": 110.0,
        "end": 120.0,
        "lines": [
          {
            "quenya": "Raumo tula, hlarë rómë,",
            "english": "Storm is coming, hear the sound,"
          },
          {
            "quenya": "calma rista menel,",
            "english": "Lightning cuts across the sky,"
          },
          {
            "quenya": "lossë ar aiwë lanta cemen,",
            "english": "Snow and hail fall to the ground,"
          },
          {
            "quenya": "valiëa túrë orta",
            "english": "Nature’s power rising high"
          }
        ]
      },
      {
        "name": "Resolution",
        "start": 120.0,
        "end": 140.0,
        "lines": [
          {
            "quenya": "Ar lómë enta tula,",
            "english": "Then the silence comes again,"
          },
          {
            "quenya": "isil or ar eleni cala,",
            "english": "Moon above and stars so bright,"
          },
          {
            "quenya": "mi i nórë varya ar auta,",
            "english": "In this world of loss and gain,"
          },
          {
            "quenya": "nárë lindë aurë ar lómë",
            "english": "Nature sings… through day and night"
          }
        ]
      }
    ],
